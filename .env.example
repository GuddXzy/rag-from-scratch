# ============================================
# LangChain Docs RAG — Environment Variables
# Copy this file to .env and adjust as needed
# ============================================

# ── LLM (Ollama — default, fully offline) ──────────────────────────────────
# Requires Ollama running locally: https://ollama.ai
# Pull model first: ollama pull qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b

# ── Embedding model (downloaded automatically on first run, ~80 MB) ────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Vector database ────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db

# ── Chunking (empirically selected via chunk-size experiment) ──────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=102

# ── Retrieval ──────────────────────────────────────────────────────────────
TOP_K=5

# ── API server ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
